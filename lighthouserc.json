{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter @agentle-ui/www preview --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/example"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }]
      }
    }
  }
}
