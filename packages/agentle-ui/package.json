{
  "name": "agentle-ui",
  "version": "0.1.0",
  "description": "A gentle UI for chaotic AI streams — headless hooks for AI-native presentation",
  "author": "edvardhov",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "registry"
  ],
  "bin": {
    "agentle-ui": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "size-limit": "^11.2.0",
    "tsup": "^8.5.0",
    "vitest": "^3.2.3"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "15 KB",
      "gzip": true
    }
  ]
}
