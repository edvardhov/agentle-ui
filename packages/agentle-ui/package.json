{
  "name": "agentle-ui",
  "version": "0.4.0",
  "description": "A gentle UI for chaotic AI streams — headless hooks for AI-native presentation",
  "author": "edvardhov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edvardhov/agentle-ui.git",
    "directory": "packages/agentle-ui"
  },
  "homepage": "https://edvardhov.github.io/agentle-ui",
  "bugs": {
    "url": "https://github.com/edvardhov/agentle-ui/issues"
  },
  "keywords": [
    "react",
    "ai",
    "streaming",
    "markdown",
    "ui",
    "hooks",
    "agent",
    "chatbot",
    "llm"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "registry",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agentle-ui": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "size-limit": "^11.2.0",
    "tsup": "^8.5.0",
    "vitest": "^3.2.3"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "15 KB",
      "gzip": true
    }
  ]
}
